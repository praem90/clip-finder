{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "clipfinder",
  "version": "0.1.0",
  "identifier": "live.streamspace.clipfinder",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "clipfinder",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI0QUNGQzczODIwMDNCOEYKUldTUE93Q0NjL3lzSkNvb0VOL3ozWVBNN2p1ZnRXOU1vVGNEQnFRVGRSVG00dXEwTndkWFROVUYK",
      "endpoints": [
        "https://github.com/praem90/clip-finder/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "icons/32x32.png": "icons/32x32.png"
    }
  }
}
